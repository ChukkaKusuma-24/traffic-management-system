// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OPERATOR
  ANALYST
  EMERGENCY_RESPONDER
  TRAFFIC_POLICE
  USER
}

enum SignalColor {
  RED
  YELLOW
  GREEN
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum NotificationChannel {
  IN_APP
  SMS
  EMAIL
}

enum EmergencyType {
  AMBULANCE
  FIRE
  POLICE
  DISASTER
}

enum SystemHealthStatus {
  HEALTHY
  DEGRADED
  CRITICAL
}

model User {
  id               String           @id @default(uuid())
  name             String
  email            String           @unique
  passwordHash     String
  role             UserRole         @default(OPERATOR)
  isActive         Boolean          @default(true)
  signalChanges    SignalState[]
  reportedIncidents Incident[]
  emergencyEvents  EmergencyEvent[]
  notifications    Notification[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Junction {
  id               String             @id @default(uuid())
  name             String
  code             String             @unique
  latitude         Float
  longitude        Float
  area             String
  isActive         Boolean            @default(true)
  trafficLogs      TrafficLog[]
  predictions      TrafficPrediction[]
  signalStates     SignalState[]
  incidents        Incident[]
  emergencyRoutes  EmergencyRoute[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([area])
}

model TrafficLog {
  id                String   @id @default(uuid())
  junctionId        String
  vehicleCount      Int
  averageSpeedKmph  Float
  congestionLevel   Float
  recordedAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  junction          Junction @relation(fields: [junctionId], references: [id], onDelete: Cascade)

  @@index([junctionId, recordedAt])
  @@index([recordedAt])
}

model TrafficPrediction {
  id                    String   @id @default(uuid())
  junctionId            String
  predictedCongestion   Float
  predictedVehicleCount Int
  confidenceScore       Float
  predictedFor          DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  junction              Junction @relation(fields: [junctionId], references: [id], onDelete: Cascade)

  @@index([junctionId, predictedFor])
}

model SignalState {
  id            String      @id @default(uuid())
  junctionId    String
  changedById   String?
  currentColor  SignalColor
  cycleTimeSec  Int
  effectiveFrom DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  junction      Junction    @relation(fields: [junctionId], references: [id], onDelete: Cascade)
  changedBy     User?       @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([junctionId, effectiveFrom])
}

model Incident {
  id                String           @id @default(uuid())
  junctionId        String
  reportedById      String?
  title             String
  description       String
  severity          IncidentSeverity
  status            IncidentStatus   @default(OPEN)
  occurredAt        DateTime
  resolvedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  junction          Junction         @relation(fields: [junctionId], references: [id], onDelete: Cascade)
  reportedBy        User?            @relation(fields: [reportedById], references: [id], onDelete: SetNull)
  emergencyEvents   EmergencyEvent[]

  @@index([junctionId, status, severity])
  @@index([occurredAt])
}

model EmergencyEvent {
  id             String          @id @default(uuid())
  incidentId     String?
  triggeredById  String?
  type           EmergencyType
  priority       Int             @default(1)
  description    String
  startedAt      DateTime        @default(now())
  endedAt        DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  incident       Incident?       @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  triggeredBy    User?           @relation(fields: [triggeredById], references: [id], onDelete: SetNull)
  routes         EmergencyRoute[]

  @@index([type, startedAt])
}

model EmergencyRoute {
  id               String         @id @default(uuid())
  emergencyEventId String
  junctionId       String
  routeOrder       Int
  etaMinutes       Int
  isCleared        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  emergencyEvent   EmergencyEvent @relation(fields: [emergencyEventId], references: [id], onDelete: Cascade)
  junction         Junction       @relation(fields: [junctionId], references: [id], onDelete: Cascade)

  @@unique([emergencyEventId, junctionId])
  @@index([junctionId, isCleared])
}

model Notification {
  id           String              @id @default(uuid())
  recipientId  String?
  title        String
  message      String
  channel      NotificationChannel @default(IN_APP)
  isRead       Boolean             @default(false)
  createdAt    DateTime            @default(now())
  readAt       DateTime?
  recipient    User?               @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([recipientId, isRead, createdAt])
}

model SystemHealthMetric {
  id                  String             @id @default(uuid())
  serviceName         String
  status              SystemHealthStatus
  cpuUsagePercent     Float
  memoryUsagePercent  Float
  responseTimeMs      Int
  activeSocketClients Int
  recordedAt          DateTime           @default(now())
  createdAt           DateTime           @default(now())

  @@index([serviceName, recordedAt])
  @@index([status, recordedAt])
}
